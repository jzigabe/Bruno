meta {
  name: Sign in
  type: http
  seq: 1
}

post {
  url: {{basepoint}}/auth/signin
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "password": "password"
  }
}

vars:pre-request {
  email: jos.zigabe@gmail.com
  password: {{localUserPassword}}
}

script:post-response {
  const body = res.getBody();
  
  bru.setVar("userToken", body.token);
  console.log(bru.getAllVars());
}

settings {
  encodeUrl: true
  timeout: 0
}
