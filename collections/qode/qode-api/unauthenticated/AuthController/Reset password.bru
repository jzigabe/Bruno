meta {
  name: Reset password
  type: http
  seq: 5
}

post {
  url: {{basepoint}}/auth/password/reset
  body: json
  auth: none
}

body:json {
  {
    "token" : "{{token}}",
    "newPassword" : "{{newPassword}}"
  }
}

vars:pre-request {
  newPassword: kkkkkk
}

settings {
  encodeUrl: true
  timeout: 0
}
